<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pos.controllers.ProductsController"
      spacing="16"
      styleClass="screen-root">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <VBox spacing="4">
        <Label text="Products" styleClass="screen-title"/>
        <Label text="Manage your product catalog" styleClass="screen-subtitle"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ Add Product"  onAction="#handleAdd"    styleClass="btn-primary"/>
        <Button text="Edit"           onAction="#handleEdit"   styleClass="btn-secondary"/>
        <Button text="Delete"         onAction="#handleDelete" styleClass="btn-danger"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Filter:" styleClass="filter-label"/>
        <ComboBox fx:id="categoryFilter" onAction="#filterByCategory" prefWidth="160" promptText="All Categories"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="idCol"        text="ID"       prefWidth="60"  minWidth="50"/>
            <TableColumn fx:id="nombreCol"    text="Name"     prefWidth="220" minWidth="120"/>
            <TableColumn fx:id="precioCol"    text="Price"    prefWidth="100" minWidth="80"/>
            <TableColumn fx:id="stockCol"     text="Stock"    prefWidth="80"  minWidth="60"/>
            <TableColumn fx:id="categoriaCol" text="Category" prefWidth="160" minWidth="100"/>
        </columns>
    </TableView>
</VBox>
