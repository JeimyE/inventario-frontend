<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pos.controllers.CategoriesController"
      spacing="16"
      styleClass="screen-root">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <VBox spacing="4">
        <Label text="Categories" styleClass="screen-title"/>
        <Label text="Manage product categories" styleClass="screen-subtitle"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ Add Category" onAction="#handleAdd"    styleClass="btn-primary"/>
        <Button text="Delete"         onAction="#handleDelete" styleClass="btn-danger"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="idCol"     text="ID"   prefWidth="80"  minWidth="60"/>
            <TableColumn fx:id="nombreCol" text="Name" prefWidth="320" minWidth="160"/>
        </columns>
    </TableView>
</VBox>
