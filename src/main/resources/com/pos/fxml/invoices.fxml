<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pos.controllers.InvoicesController"
      spacing="16"
      styleClass="screen-root">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <VBox spacing="4">
        <Label text="Invoices" styleClass="screen-title"/>
        <Label text="View and create sales invoices" styleClass="screen-subtitle"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ New Invoice"  onAction="#handleNewInvoice"  styleClass="btn-primary"/>
        <Button text="Download PDF"   onAction="#handleDownloadPdf" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="idCol"      text="ID"      prefWidth="60"  minWidth="50"/>
            <TableColumn fx:id="fechaCol"   text="Date"    prefWidth="140" minWidth="100"/>
            <TableColumn fx:id="clienteCol" text="Client"  prefWidth="200" minWidth="120"/>
            <TableColumn fx:id="cajeroCol"  text="Cashier" prefWidth="160" minWidth="100"/>
            <TableColumn fx:id="totalCol"   text="Total"   prefWidth="120" minWidth="80"/>
        </columns>
    </TableView>
</VBox>
