<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pos.controllers.MainController">

    <left>
        <VBox styleClass="sidebar" prefWidth="210" spacing="0">

            <VBox styleClass="sidebar-header" spacing="2">
                <padding><Insets top="24" right="16" bottom="20" left="16"/></padding>
                <Label text="POS System" styleClass="sidebar-title"/>
                <Label text="Inventory Manager" styleClass="sidebar-subtitle"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <Button fx:id="dashboardBtn"   text="  Dashboard"   onAction="#showDashboard"   styleClass="nav-btn" maxWidth="Infinity"/>
            <Button fx:id="productsBtn"    text="  Products"    onAction="#showProducts"    styleClass="nav-btn" maxWidth="Infinity"/>
            <Button fx:id="clientsBtn"     text="  Clients"     onAction="#showClients"     styleClass="nav-btn" maxWidth="Infinity"/>
            <Button fx:id="cashiersBtn"    text="  Cashiers"    onAction="#showCashiers"    styleClass="nav-btn" maxWidth="Infinity"/>
            <Button fx:id="categoriesBtn"  text="  Categories"  onAction="#showCategories"  styleClass="nav-btn" maxWidth="Infinity"/>
            <Button fx:id="invoicesBtn"    text="  Invoices"    onAction="#showInvoices"    styleClass="nav-btn" maxWidth="Infinity"/>
            <Button fx:id="statisticsBtn"  text="  Statistics"  onAction="#showStatistics"  styleClass="nav-btn" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-separator"/>
            <Button text="  Logout" onAction="#handleLogout" styleClass="nav-btn-logout" maxWidth="Infinity"/>
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-area"/>
    </center>
</BorderPane>
