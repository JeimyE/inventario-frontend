<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pos.controllers.InvoiceDialogController"
      spacing="18"
      styleClass="screen-root">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <Label text="New Invoice" styleClass="screen-title"/>

    <!-- Client selection -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Client:" styleClass="form-label" minWidth="70"/>
        <ComboBox fx:id="clientCombo" prefWidth="280" promptText="Select a client"/>
    </HBox>

    <Separator/>

    <!-- Product lines header -->
    <HBox spacing="10">
        <Label text="Product Lines" styleClass="form-section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Line" onAction="#addLine" styleClass="btn-secondary-small"/>
    </HBox>

    <!-- Scrollable lines area -->
    <ScrollPane fitToWidth="true" prefHeight="240" styleClass="lines-scroll">
        <VBox fx:id="linesContainer" spacing="4">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
        </VBox>
    </ScrollPane>

    <Separator/>

    <!-- Total -->
    <HBox alignment="CENTER_RIGHT">
        <Label fx:id="totalLabel" text="Total: $0.00" styleClass="invoice-total"/>
    </HBox>

    <!-- Action buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button fx:id="saveBtn" text="Save Invoice" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
